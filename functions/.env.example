# gift-system Cloud Functions 環境変数（サンプル）
#
# ★ 実値を入れた .env / .env.<project> は **絶対にコミットしない**（.gitignore 済み）。
#   このファイル（.env.example）だけをコミットし、必要なキーの一覧を共有する。
#
# ネクストエンジン（NE）連携用（design.md 第6章）。
#
# ★ client_id / client_secret は **Secret Manager** で管理する（.env には置かない）。
#   登録: firebase functions:secrets:set NE_CLIENT_ID
#         firebase functions:secrets:set NE_CLIENT_SECRET
#   これらは認証交換(/api_neauth)を行う neCallback にのみ注入される（config/secrets.ts）。
# ★ access/refresh トークンは Firestore（neAuth/tokens）にローテーション保存するため、ここには置かない。

# NE API のベースURL（本番/検証で切り替え）。
NE_API_BASE=https://api.next-engine.org

# 投入モード: auto（Cloud Functions から NE API 自動投入）/ csv（CSV出力で手動・日次取込）。
# 既定は安全側の csv。auto にしても下の NE_UPLOAD_PATTERN_ID（受注一括登録パターンID=11）が揃うまで
# 自動投入は無効（isNeAutoConfigured）。★段階テストが済むまでは csv のままにしておくこと。
NE_MODE=csv

# 受注一括登録パターンID（アップロードAPIに渡す・店舗2のギフト用=11）。★NE管理画面で有効化してから設定する。
#   未設定（空）＝自動投入は無効のまま（安全側）。
NE_UPLOAD_PATTERN_ID=

# 以下は既定値があるため通常は未設定でよい（上書きしたいときだけ設定）。
#   NE_AUTH_ENDPOINT=/api_neauth
#   NE_UPLOAD_ENDPOINT=/api_v1_receiveorder_base/upload
#   NE_QUE_ENDPOINT=/api_v1_system_que/search
#   NE_WAIT_FLAG=1
#   NE_STORE_CODE=2

# 受け取り者URLの生成に使う公開ホスト（例: https://gift-system-f33b5.web.app）。
PUBLIC_HOSTING_ORIGIN=
