{
  "name": "gift-system-functions",
  "description": "gift-system Cloud Functions（TypeScript / 2nd gen / Node.js 22）",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "lib/functions/src/index.js",
  "scripts": {
    "lint": "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint --ext .ts src",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc",
    "build:watch": "tsc --watch",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=4096 mocha",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.1.0",
    "iconv-lite": "^0.6.3",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "^20.16.0",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "mocha": "^10.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
