{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "ignore": [
      "node_modules",
      ".git",
      "scripts",
      "test",
      ".mocharc.json",
      "*.local"
    ],
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  },
  "hosting": {
    "public": "web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "predeploy": [
      "node -e \"const fs=require('fs');fs.mkdirSync('web/shared',{recursive:true});fs.copyFileSync('shared/constants.js','web/shared/constants.js')\""
    ],
    "rewrites": [
      { "source": "/api/adminGenerateGiftCards", "function": { "functionId": "adminGenerateGiftCards", "region": "asia-northeast1" } },
      { "source": "/api/receiveGetCard", "function": { "functionId": "receiveGetCard", "region": "asia-northeast1" } },
      { "source": "/api/receiveConfirm", "function": { "functionId": "receiveConfirm", "region": "asia-northeast1" } },
      { "source": "/api/adminExportNeCsv", "function": { "functionId": "adminExportNeCsv", "region": "asia-northeast1" } },
      { "source": "/api/adminRetryNeSubmissions", "function": { "functionId": "adminRetryNeSubmissions", "region": "asia-northeast1" } },
      { "source": "/api/neCallback", "function": { "functionId": "neCallback", "region": "asia-northeast1" } },
      { "source": "/api/neCallbackTest", "function": { "functionId": "neCallbackTest", "region": "asia-northeast1" } },
      { "source": "/api/adminExportUrlXlsx", "function": { "functionId": "adminExportUrlXlsx", "region": "asia-northeast1" } },
      { "source": "/g/**", "destination": "/receive/index.html" },
      { "source": "/admin/**", "destination": "/admin/index.html" }
    ]
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "functions": { "port": 5001 },
    "hosting": { "port": 5000 },
    "storage": { "port": 9199 },
    "ui": { "enabled": true }
  }
}
