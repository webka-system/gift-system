# gift-system Cloud Functions 環境変数（サンプル）
#
# ★ 実値を入れた .env / .env.<project> は **絶対にコミットしない**（.gitignore 済み）。
#   このファイル（.env.example）だけをコミットし、必要なキーの一覧を共有する。
#
# ネクストエンジン（NE）連携用（design.md 第6章）。
# ★ client_id / client_secret は静的な秘匿値。access/refresh トークンは .env ではなく
#   Firestore（neAuth/tokens）にローテーション保存するため、ここには置かない。
NE_CLIENT_ID=
NE_CLIENT_SECRET=
# NE API のベースURL（本番/検証で切り替え）。
NE_API_BASE=https://api.next-engine.org

# 投入モード: auto（Cloud Functions から NE API 自動投入）/ csv（CSV出力で手動・日次取込）。
# 既定は安全側の csv。auto にしても下の NE_ORDER_ENDPOINT と client_id/secret が揃うまで
# 自動投入は無効（isNeAutoConfigured）。
NE_MODE=csv
# 受注登録APIのパス。★NE APIリファレンスで確定するまで空にしておく（空＝自動投入無効）。
NE_ORDER_ENDPOINT=

# 受け取り者URLの生成に使う公開ホスト（例: https://gift-system-f33b5.web.app）。
PUBLIC_HOSTING_ORIGIN=
